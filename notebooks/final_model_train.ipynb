from google.colab import drive
drive.mount('/content/drive')

import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader, TensorDataset
import numpy as np
import matplotlib.pyplot as plt
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix
import seaborn as sns
import os

print("Loading YOUR real data from Google Drive...")

# Load your real data
data_path = "/content/drive/MyDrive/drowsiness_data"

X_train = np.load(os.path.join(data_path, "X_train.npy"))
y_train = np.load(os.path.join(data_path, "y_train.npy"))
X_val = np.load(os.path.join(data_path, "X_val.npy"))
y_val = np.load(os.path.join(data_path, "y_val.npy"))
X_test = np.load(os.path.join(data_path, "X_test.npy"))
y_test = np.load(os.path.join(data_path, "y_test.npy"))

print(f"✅ Data loaded!")
print(f"Train: {X_train.shape}, Val: {X_val.shape}, Test: {X_test.shape}")

# Convert to tensors
X_train_tensor = torch.FloatTensor(X_train).permute(0,1,4,2,3)
X_val_tensor = torch.FloatTensor(X_val).permute(0,1,4,2,3)
X_test_tensor = torch.FloatTensor(X_test).permute(0,1,4,2,3)

train_loader = DataLoader(TensorDataset(X_train_tensor, torch.LongTensor(y_train)), batch_size=32, shuffle=True)
val_loader = DataLoader(TensorDataset(X_val_tensor, torch.LongTensor(y_val)), batch_size=32)
test_loader = DataLoader(TensorDataset(X_test_tensor, torch.LongTensor(y_test)), batch_size=32)

# Models
class CNNEncoder(nn.Module):
    def __init__(self):
        super().__init__()
        self.conv = nn.Sequential(
            nn.Conv2d(3, 32, 3, padding=1), nn.BatchNorm2d(32), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(32, 64, 3, padding=1), nn.BatchNorm2d(64), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(64, 128, 3, padding=1), nn.BatchNorm2d(128), nn.ReLU(), nn.AdaptiveAvgPool2d(1)
        )
        self.fc = nn.Linear(128, 128)
        self.dropout = nn.Dropout(0.3)
    def forward(self, x):
        return self.dropout(self.fc(self.conv(x).squeeze()))

class TemporalGRU(nn.Module):
    def __init__(self):
        super().__init__()
        self.gru = nn.GRU(128, 128, batch_first=True, bidirectional=True, dropout=0.3, num_layers=2)
        self.fc = nn.Linear(256, 128)
        self.dropout = nn.Dropout(0.3)
    def forward(self, x):
        out, _ = self.gru(x)
        return self.dropout(self.fc(out[:, -1, :])), out

class Autoencoder(nn.Module):
    def __init__(self):
        super().__init__()
        self.enc = nn.Sequential(nn.Linear(128, 64), nn.ReLU(), nn.Linear(64, 32))
        self.dec = nn.Sequential(nn.Linear(32, 64), nn.ReLU(), nn.Linear(64, 128))
    def forward(self, x):
        latent = self.enc(x)
        return self.dec(latent), latent

class HybridModel(nn.Module):
    def __init__(self):
        super().__init__()
        self.cnn = CNNEncoder()
        self.gru = TemporalGRU()
        self.ae = Autoencoder()
        self.classifier = nn.Sequential(nn.Linear(128, 64), nn.ReLU(), nn.Dropout(0.5), nn.Linear(64, 2))
    def forward(self, x):
        b, t, c, h, w = x.shape
        features = [self.cnn(x[:, i]) for i in range(t)]
        gru_out, _ = self.gru(torch.stack(features, dim=1))
        recon, latent = self.ae(gru_out)
        ae_loss = nn.MSELoss()(recon, gru_out.detach())
        return self.classifier(gru_out), ae_loss

device = 'cuda' if torch.cuda.is_available() else 'cpu'
model = HybridModel().to(device)
optimizer = optim.Adam(model.parameters(), lr=0.001, weight_decay=1e-5)
criterion = nn.CrossEntropyLoss()

print(f"\nUsing device: {device}")
print(f"Total parameters: {sum(p.numel() for p in model.parameters()):,}")

print("\nStarting REAL training (30-45 minutes)...")
print("="*50)

train_losses = []
val_accuracies = []
best_val_acc = 0

for epoch in range(50):
    model.train()
    total_loss = 0
    for x, y in train_loader:
        x, y = x.to(device), y.to(device)
        optimizer.zero_grad()
        logits, ae_loss = model(x)
        loss = criterion(logits, y) + 0.5 * ae_loss
        loss.backward()
        optimizer.step()
        total_loss += loss.item()

    model.eval()
    correct = 0
    with torch.no_grad():
        for x, y in val_loader:
            x, y = x.to(device), y.to(device)
            logits, _ = model(x)
            correct += (logits.argmax(1) == y).sum().item()
    val_acc = correct / len(val_loader.dataset)
    train_losses.append(total_loss/len(train_loader))
    val_accuracies.append(val_acc)

    print(f"Epoch {epoch+1:2d}/50 | Loss: {total_loss/len(train_loader):.4f} | Val Acc: {val_acc:.4f}")

    if val_acc > best_val_acc:
        best_val_acc = val_acc
        torch.save(model.state_dict(), 'best_model.pth')

print("="*50)
print(f"Best validation accuracy: {best_val_acc:.4f}")

# Test
model.load_state_dict(torch.load('best_model.pth'))
model.eval()
all_preds, all_labels = [], []

with torch.no_grad():
    for x, y in test_loader:
        x, y = x.to(device), y.to(device)
        logits, _ = model(x)
        all_preds.extend(logits.argmax(1).cpu().numpy())
        all_labels.extend(y.cpu().numpy())

print("\n" + "="*50)
print("TEST RESULTS")
print("="*50)
print(f"Accuracy:  {accuracy_score(all_labels, all_preds):.4f}")
print(f"Precision: {precision_score(all_labels, all_preds, average='binary'):.4f}")
print(f"Recall:    {recall_score(all_labels, all_preds, average='binary'):.4f}")
print(f"F1-Score:  {f1_score(all_labels, all_preds, average='binary'):.4f}")
print("="*50)

# Confusion Matrix
cm = confusion_matrix(all_labels, all_preds)
plt.figure(figsize=(6,5))
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=['Alert', 'Drowsy'], yticklabels=['Alert', 'Drowsy'])
plt.title('Confusion Matrix')
plt.savefig('confusion_matrix.png')
plt.show()

print("\n Training complete!")
